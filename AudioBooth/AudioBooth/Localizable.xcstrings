    "Drag to reorder enabled sections. Continue Listening and Continue Reading cannot be disabled." : {
      "comment" : "A footer description for the list of home sections in the preferences view.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Træk for at omarrangere aktiverede sektioner. \"Fortsæt med at lytte\" og \"Fortsæt med at læse\" kan ikke deaktiveres."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ziehe, um aktivierte Bereiche neu zu ordnen. Weiterhören und Weiterlesen können nicht deaktiviert werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arrastra para reordenar las secciones activadas. Seguir escuchando y Seguir leyendo no se pueden desactivar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites glisser pour réordonner les sections. Continuer l'écoute et Continuer la lecture ne peuvent pas être désactivés."
          }
        },
        "zh-TW" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拖曳以重新排序已啟用的區塊。「繼續聆聽」和「繼續閱讀」無法停用。"
          }
        }
      }
    },
    "Drag to reorder. Disabled controls move to the player menu." : {
      "comment" : "A footer description below the controls section of the player preferences view, explaining how to reorder and disable controls.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "da" : {
