          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies löscht alle heruntergeladenen Hörbücher und E-Books. Du kannst sie später erneut laden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
